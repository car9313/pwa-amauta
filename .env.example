# ============================================================
# Amauta — Variables de entorno
# Copia este archivo como .env.development o .env.production
# yrellena los valores reales. NUNCA subas los valores
# reales al repositorio.
# ============================================================

# ------------------------------------------------------------
# API
# ------------------------------------------------------------

# URL base del backend. Cambiar por entorno.
# Desarrollo:   https://api-dev.amauta.axentra.io
# Staging:      https://api-staging.amauta.axentra.io
# Producción:   https://api.amauta.axentra.io
VITE_API_BASE_URL=

# Versión del API (ej: v1)
VITE_API_VERSION=v1

# Timeout en milisegundos para las llamadas al API (default: 10000)
VITE_API_TIMEOUT=10000

# ------------------------------------------------------------
# Autenticación
# ------------------------------------------------------------

# Nombre de la clave donde se guarda el JWT (localStorage / cookie)
VITE_AUTH_TOKEN_KEY=amauta_token

# Tiempo de expiración del token en minutos
VITE_AUTH_TOKEN_EXPIRY_MINUTES=60

# ------------------------------------------------------------
# Mocks (desarrollo)
# ------------------------------------------------------------

# Activa los datos mock en lugar de llamar al API real.
# Útil mientras el backend no está listo.
# Valores: true | false
VITE_USE_MOCK=true

# ------------------------------------------------------------
# PWA / Caché
# ------------------------------------------------------------

# Tiempo en segundos que TanStack Query considera los datos frescos
VITE_QUERY_STALE_TIME=60

# ------------------------------------------------------------
# App
# ------------------------------------------------------------

# Nombre de la app (usado en el manifest de la PWA)
VITE_APP_NAME=Amauta

# Versión de la app (usada en Sentry releases)
VITE_APP_VERSION=0.1.0

# Ambiente actual: development | staging | production
VITE_APP_ENV=development

# Activar logs de debug en consola
# Valores: true | false
VITE_DEBUG=true

# ------------------------------------------------------------
# Sentry (Error Tracking)
# ------------------------------------------------------------

# DSN de Sentry para enviar errores en producción
# Obtener de: Settings → Projects → [proyecto] → DSN
# Dejar vacío para deshabilitar Sentry
VITE_SENTRY_DSN=

# ------------------------------------------------------------
# Sentry Source Maps (Build-time only)
# ------------------------------------------------------------

# Auth token para upload de source maps a Sentry
# Generar en: Settings → Auth Tokens
SENTRY_AUTH_TOKEN=
# Organización en Sentry
SENTRY_ORG=amauta
# Proyecto en Sentry
SENTRY_PROJECT=amauta-web